#!/usr/bin/env bash
# Run a demo from a subtask worktree
#
# Usage:
#   demo-worktree <task> [demo-path]
#
# Examples:
#   demo-worktree cells/big-text                    # lists demos in that worktree
#   demo-worktree cells/big-text demo_big_text.py   # runs demos/cells/demo_big_text.py
#   demo-worktree cells/mouse-research demo_mouse   # .py suffix optional
#
# The script finds the worktree for the given task and runs the demo there.

set -euo pipefail

if [[ $# -lt 1 ]]; then
    echo "Usage: demo-worktree <task> [demo-path] [args...]"
    echo ""
    echo "Tasks with worktrees:"
    subtask list 2>/dev/null | awk 'NR>1 && $1 !~ /^$/ {print "  " $1}' | head -20
    exit 1
fi

TASK="$1"
shift

# Get the workspace path
WORKSPACE=$(subtask workspace "$TASK" 2>/dev/null) || {
    echo "Error: Could not find worktree for task '$TASK'"
    echo ""
    echo "Available tasks:"
    subtask list 2>/dev/null | awk 'NR>1 && $1 !~ /^$/ {print "  " $1}' | head -20
    exit 1
}

DEMOS_DIR="$WORKSPACE/demos/cells"

# If no demo specified, list available demos
if [[ $# -lt 1 ]]; then
    echo "Worktree: $WORKSPACE"
    echo ""
    if [[ -d "$DEMOS_DIR" ]]; then
        echo "Available demos in demos/cells/:"
        ls -1 "$DEMOS_DIR"/*.py 2>/dev/null | xargs -n1 basename | sed 's/^/  /'
    else
        echo "No demos/cells/ directory found"
    fi
    exit 0
fi

DEMO="$1"
shift

# Add .py if missing
[[ "$DEMO" == *.py ]] || DEMO="${DEMO}.py"

# Find the demo file
DEMO_PATH=""
if [[ -f "$DEMOS_DIR/$DEMO" ]]; then
    DEMO_PATH="$DEMOS_DIR/$DEMO"
elif [[ -f "$WORKSPACE/$DEMO" ]]; then
    DEMO_PATH="$WORKSPACE/$DEMO"
elif [[ -f "$WORKSPACE/demos/$DEMO" ]]; then
    DEMO_PATH="$WORKSPACE/demos/$DEMO"
else
    echo "Error: Demo '$DEMO' not found in worktree"
    echo ""
    echo "Searched:"
    echo "  $DEMOS_DIR/$DEMO"
    echo "  $WORKSPACE/$DEMO"
    echo ""
    if [[ -d "$DEMOS_DIR" ]]; then
        echo "Available demos:"
        ls -1 "$DEMOS_DIR"/*.py 2>/dev/null | xargs -n1 basename | sed 's/^/  /'
    fi
    exit 1
fi

echo "Running: $DEMO_PATH"
echo "─────────────────────────────────────"
cd "$WORKSPACE"
exec uv run python "$DEMO_PATH" "$@"
