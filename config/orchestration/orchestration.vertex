// orchestration — task dispatch and worker lifecycle management.
//
// The orchestrator agent manages implementation work: dispatches tasks
// to workers, selects models, triages questions, coordinates merges.
//
// Two-phase dispatch:
//   status=open    → orchestrator assesses (model selection, context gathering)
//   status=assigned → dispatch script creates worktree, launches worker
//
// No daemon. Sync heartbeat from session hooks evaluates boundaries.
name "orchestration"
store "./data/orchestration.db"

observers {
  kyle { }
  loops-claude { }
  orchestrator { }
}

loops {
  // Tasks — the work items. Fold by name, latest status wins.
  // Lifecycle: open → assessed → assigned → running → review → completed → merged
  task {
    fold { items "by" "name" }

    // Phase 1: orchestrator assesses — model selection, context enrichment
    boundary when="task" status="open" {
      run "./scripts/assess.sh"
    }
  }

  // Workers — active worker state tracking.
  // Fold by name: model, branch, worktree path, status.
  worker {
    fold { items "by" "name" }

    // Phase 2: mechanical dispatch — create worktree, launch worker
    boundary when="worker" status="assigned" {
      run "./scripts/dispatch.sh"
    }
  }

  // Questions — worker questions needing triage.
  // Orchestrator answers what it can, escalates what it can't.
  question {
    fold { items "by" "name" }
  }
}
