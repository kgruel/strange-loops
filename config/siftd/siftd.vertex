// siftd — conversation search (aggregation)
// Combines harness-specific child vertices. No own store.

name "siftd"

lens {
    fold "fold"
}

combine {
  vertex "./claude-code/claude-code.vertex"
}

loops {
  exchange {
    fold {
      items "by" "conversation_id"
      count "inc"
      updated "latest"
    }
    search "prompt" "response"
  }

  tag {
    fold {
      items "by" "name"
    }
  }
}
