name "check"
store "./data/check.db"

sources sequential {
  source "uv run ruff format --check src/ tests/" {kind "fmt.result"}
  source "uv run ruff check src/" {kind "lint.result"}
  source "uv run pytest tests/ -q --tb=line" {kind "test.result"}
}

loops {
  fmt.result { fold { items "latest" } }
  lint.result { fold { items "latest" } }
  test.result { fold { items "latest" } }
}
