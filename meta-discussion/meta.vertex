// meta — cross-cutting patterns, ways of working, design principles
// Not loops-specific. Decisions here survive outside any single project.
// Loops-specific architecture goes in project.vertex.
name "meta"
store "./data/meta.db"

lens {
  fold "meta"
}

loops {
  decision    { fold { items "by" "topic" } }
  thread      { fold { items "by" "name" } }
  dissolution { fold { items "by" "concept" } }
  session     { fold { items "by" "name" } }
}
