// FRED API — fetch recent observations for a time series
// Template vars: {{series_id}}, {{kind}}, {{every}}
// Requires: FRED_API_KEY environment variable

source #"curl -sf "https://api.stlouisfed.org/fred/series/observations?series_id={{series_id}}&api_key=${FRED_API_KEY}&file_type=json&sort_order=desc&limit=10""#
every "{{every}}"
kind "{{kind}}"
observer "fred"
format "json"

parse {
  explode path="observations"
  project {
    date path="date"
    value path="value"
  }
}
