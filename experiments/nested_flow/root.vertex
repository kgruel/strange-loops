# Root vertex: top-level aggregation
# Demonstrates discover: for auto-discovering nested .vertex files
name: root

sources:
    - timers/*.loop
    - sources/*.loop

# discover: auto-finds all .vertex files in the infra/ subdirectory
discover: ./infra/*.vertex

loops:
    health:
        fold:
            events: collect 100
        boundary: when infra.health

emit: system.report
