// Root vertex: top-level aggregation of all domains
name "root"

sources {
  path "./timers/second.loop"
  path "./timers/minute.loop"
}

vertices "./infra.vertex" "./personal.vertex"

loops {
  overview {
    fold {
      reports "collect" 100
    }
    boundary when="infra.status"
  }
}

emit "system.snapshot"
