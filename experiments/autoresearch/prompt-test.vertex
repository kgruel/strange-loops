name "autoresearch/prompt-test"
store "./data/prompt-test.db"

loops {
  // --- Turn-completing fact (SYSTEM EMITS ONLY) ---
  // The experiment fact signals iteration-complete. Boundary fires on it.
  // One experiment = one tick = one agent turn.
  experiment {
    fold { items "collect" 50; n "count" }
    boundary after=5  // completion tick at batch end
  }

  // --- Supporting facts (AGENT EMITS) ---

  // Knowledge map — current understanding of each code area.
  // Folded by target — upserts as understanding deepens across turns.
  // target is namespaced: "fold/computation", "import/chain", "store/queries"
  finding {
    fold { items "by" "target" }
  }

  // Sequential narrative — what happened this iteration.
  // type=approach|result|observation, message, files, ref (cross-link)
  // Ephemeral: recent history for context, not durable knowledge.
  log {
    fold { items "collect" 20 }
  }

  // Testable predictions — folded by name, status updates in place.
  // proposed → confirmed|rejected as evidence accumulates across turns.
  // Namespaced: "fold/batch-query", "lens/column-overhead"
  hypothesis {
    fold { items "by" "name" }
  }

  // Things to try — folded by name, status updates in place.
  // untried → tried|rejected as iterations proceed.
  idea {
    fold { items "by" "name" }
  }

  // --- Configuration (SEEDED AT INIT) ---
  // objective, primary_metric, direction, scope, benchmark, checks
  config {
    fold { items "by" "key" }
  }

  // --- Iteration control ---
  // Boundary fires when experiment fact lands and count < limit.
  // Run clause is the iterate script — spawns agent, benchmarks, emits.
  // This IS the agent loop. Vertex orchestrates the cycle.
  boundary when="experiment" {
    condition "n" "<" 5
    run "/Users/kaygee/Code/loops/iterate.sh"
  }
}

lens {
  fold "autoresearch"
}
