#!/usr/bin/env bash
set -euo pipefail

agent="${1:?Usage: launch <agent-name> [working-dir]}"
workdir="${2:-.}"

# Resolve loops binary from the monorepo venv
REPO_ROOT="$(cd -P "$(dirname "$0")/../.." && pwd)"
LOOPS="${REPO_ROOT}/.venv/bin/loops"

if [[ ! -x "$LOOPS" ]]; then
  echo "error: loops binary not found at $LOOPS" >&2
  exit 1
fi

# Identity belongs to the agent, not the delegation path
# Read identity using the bare agent name (identity store is observer-scoped)
identity=$("$LOOPS" read identity --observer "$agent" --plain 2>/dev/null || true)

if [[ -z "$identity" ]]; then
  echo "warning: no identity found for observer '$agent'" >&2
fi

# Emit session start — principal=kyle, agent name in payload for provenance
"$LOOPS" emit session session principal=kyle agent="$agent" status=open 2>/dev/null || true

# Namespaced observer: principal/agent — carries delegation provenance.
# Matching at all sites understands that kyle/loops-claude matches
# a bare declaration of loops-claude (backward compatible).
observer="kyle/$agent"

# Start claude as the agent — namespaced observer for full provenance
cd "$workdir"
exec env LOOPS_OBSERVER="$observer" claude --system-prompt "$identity"
