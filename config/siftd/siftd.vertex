// siftd — conversation search (aggregation)
// Combines harness-specific child vertices. No own store.

name "siftd"

lens {
    fold "fold"
}

combine {
  vertex "./claude-code/claude-code.vertex"
}

loops {
  record {
    fold {
      items "by" "sessionId"
      count "inc"
      updated "latest"
    }
    search "message.content"
  }

  tag {
    fold {
      items "by" "name"
    }
  }
}
