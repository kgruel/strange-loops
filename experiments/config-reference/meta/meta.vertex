// meta — cross-cutting patterns and ways of working
// Pure domain aggregation. Identity and comms are siblings under the root,
// not children of meta.
name "meta"

combine {
    vertex "/Users/kaygee/Code/meta-discussion/meta.vertex"
}

observers {
  meta-claude { }
  kyle { }
}

loops {
  decision    { fold { items "by" "topic" } }
  thread      { fold { items "by" "name" } }
  task        { fold { items "by" "name" } }
  session     { fold { items "by" "name" } }
  dissolution { fold { items "by" "concept" } }
}
